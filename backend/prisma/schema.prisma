generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Clinic {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  phone     String?
  address   String?
  createdAt DateTime @default(now())

  users           User[]
  patients        Patient[]
  services        Service[]
  appointments    Appointment[]
  packages        Package[]
  patientPackages PatientPackage[]
  rooms           Room[]
  products        Product[]
  materials       Material[]
  usages          TreatmentUsage[]
}

enum Role {
  ADMIN
  DOCTOR
  ASSISTANT
  STAFF
}

model User {
  id        Int      @id @default(autoincrement())
  clinicId  Int
  name      String
  email     String
  password  String
  role      Role     @default(STAFF)
  phone     String?
  position  String?
  specialty String?
  licenseNo String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  clinic                Clinic        @relation(fields: [clinicId], references: [id])
  doctorAppointments    Appointment[] @relation("ApptDoctor")
  assistantAppointments Appointment[] @relation("ApptAssistant")

  @@unique([clinicId, email])
}

model Patient {
  id        Int       @id @default(autoincrement())
  clinicId  Int
  code      String
  name      String
  phone     String?
  email     String?
  birthdate DateTime?
  gender    String?
  allergies String?
  note      String?
  createdAt DateTime  @default(now())

  clinic          Clinic           @relation(fields: [clinicId], references: [id])
  appointments    Appointment[]
  patientPackages PatientPackage[]
  photos          PatientPhoto[]
  usages          TreatmentUsage[]

  @@unique([clinicId, code])
}

model PatientPhoto {
  id        Int      @id @default(autoincrement())
  patientId Int
  url       String
  label     String?
  takenAt   DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])
}

model Service {
  id          Int      @id @default(autoincrement())
  clinicId    Int
  name        String
  description String?
  price       Float?
  durationMin Int?
  createdAt   DateTime @default(now())

  clinic       Clinic        @relation(fields: [clinicId], references: [id])
  appointments Appointment[]
}

model Room {
  id        Int      @id @default(autoincrement())
  clinicId  Int
  name      String
  type      String?
  note      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  clinic       Clinic        @relation(fields: [clinicId], references: [id])
  appointments Appointment[]
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  DONE
  CANCELLED
  NO_SHOW
}

model Appointment {
  id          Int               @id @default(autoincrement())
  clinicId    Int
  patientId   Int
  doctorId    Int?
  assistantId Int?
  serviceId   Int?
  roomId      Int?
  startAt     DateTime
  endAt       DateTime?
  status      AppointmentStatus @default(PENDING)
  note        String?
  treatNote   String?
  createdAt   DateTime          @default(now())

  clinic    Clinic           @relation(fields: [clinicId], references: [id])
  patient   Patient          @relation(fields: [patientId], references: [id])
  doctor    User?            @relation("ApptDoctor", fields: [doctorId], references: [id])
  assistant User?            @relation("ApptAssistant", fields: [assistantId], references: [id])
  service   Service?         @relation(fields: [serviceId], references: [id])
  room      Room?            @relation(fields: [roomId], references: [id])
  emailLogs EmailLog[]
  usages    TreatmentUsage[]
}

model Package {
  id           Int      @id @default(autoincrement())
  clinicId     Int
  name         String
  description  String?
  totalSession Int
  price        Float
  validDays    Int?
  createdAt    DateTime @default(now())

  clinic          Clinic           @relation(fields: [clinicId], references: [id])
  patientPackages PatientPackage[]
}

model PatientPackage {
  id            Int       @id @default(autoincrement())
  clinicId      Int
  patientId     Int
  packageId     Int
  sessionsTotal Int
  sessionsUsed  Int       @default(0)
  purchasedAt   DateTime  @default(now())
  expiresAt     DateTime?

  clinic   Clinic           @relation(fields: [clinicId], references: [id])
  patient  Patient          @relation(fields: [patientId], references: [id])
  package  Package          @relation(fields: [packageId], references: [id])
  sessions PackageSession[]
}

model PackageSession {
  id               Int      @id @default(autoincrement())
  patientPackageId Int
  usedAt           DateTime @default(now())
  note             String?

  patientPackage PatientPackage @relation(fields: [patientPackageId], references: [id])
}

// รายการสินค้าขายหน้าร้าน (retail products)
model Product {
  id        Int      @id @default(autoincrement())
  clinicId  Int
  name      String
  sku       String?
  category  String?
  unit      String?
  price     Float?
  cost      Float?
  stockQty  Int      @default(0)
  note      String?
  createdAt DateTime @default(now())

  clinic Clinic           @relation(fields: [clinicId], references: [id])
  usages TreatmentUsage[]
}

// วัสดุสิ้นเปลืองที่ใช้ในการรักษา (consumable materials)
model Material {
  id           Int      @id @default(autoincrement())
  clinicId     Int
  name         String
  sku          String?
  unit         String?
  cost         Float?
  stockQty     Int      @default(0)
  reorderLevel Int?
  note         String?
  createdAt    DateTime @default(now())

  clinic Clinic           @relation(fields: [clinicId], references: [id])
  usages TreatmentUsage[]
}

enum UsageType {
  PRODUCT
  MATERIAL
}

// รายการสินค้า/วัสดุที่ใช้กับคนไข้ในแต่ละนัด
model TreatmentUsage {
  id            Int       @id @default(autoincrement())
  clinicId      Int
  appointmentId Int
  patientId     Int
  itemType      UsageType
  productId     Int?
  materialId    Int?
  name          String
  qty           Int       @default(1)
  unitCost      Float?
  note          String?
  usedAt        DateTime  @default(now())

  clinic      Clinic      @relation(fields: [clinicId], references: [id])
  appointment Appointment @relation(fields: [appointmentId], references: [id])
  patient     Patient     @relation(fields: [patientId], references: [id])
  product     Product?    @relation(fields: [productId], references: [id])
  material    Material?   @relation(fields: [materialId], references: [id])
}

model EmailLog {
  id            Int      @id @default(autoincrement())
  appointmentId Int
  sentAt        DateTime @default(now())
  toEmail       String
  status        String
  error         String?

  appointment Appointment @relation(fields: [appointmentId], references: [id])
}
